#include <stdio.h>
#include <math.h> 
#include <stdlib.h> 


double gauss(int n,double *a) 
{
    int i, j, k, im;
    im=-1;
    double det=1.0;
    i = 0; 
    j = 0;
    while (i < n && j < n) 
    {
        for (k = i; k < n; k++)
            if (fabs(a[k*n + j]) > 0.00001) 
                im = k;
        if (im!=-1)
        {
            if (im != i)
            {
                for (k = j; k < n; ++k) 
                {
                    double r = a[i*n + k];
                    a[i*n + k] = a[im*n + k];
                    a[im*n + k] = r;
                }
                det=det*(-1.0);
            }
            for (k = i+1; k < n; ++k) 
            {
                double kf = (a[k*n + j] / a[i*n + j]);
                a[k*n + j] = 0.0;
                for (im = j+1; im < n; im++)
                    a[k*n + im] -= kf * a[i*n + im];
            }
            ++i; 
            ++j;
        }
        else return 0;
        
    }
    return det;
}

int main() 
{
    int n, i, j;
    double det;
    scanf("%d", &n);
    double *a = (double*)malloc(n * n * sizeof(double));
    for (i = 0; i < n; i++) 
    {
        for (j = 0; j < n; j++) 
        {
            scanf("%lf", &(a[i*n + j]));
        }
    }
    det=gauss(n, a);
    for (i = 0; i < n; ++i) 
        det=det*(a[i*n + i]);
    printf("%.3lf\n", det);
    free(a);
    return 0;
}
